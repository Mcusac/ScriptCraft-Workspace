# ============================================================
# ROOT WORKSPACE .gitignore
# Only governs the workspace repo itself
# ============================================================

# =========================
# OS / EDITOR
# =========================
.DS_Store
Thumbs.db

.vscode/
!.vscode/settings.json
!.vscode/tasks.json
!.vscode/launch.json

.idea/

# =========================
# ROOT RUNTIME / TEMP
# =========================
*.log
*.tmp
*.temp
*.bak

# =========================
# WORKSPACE DATA
# =========================

workspace/logs/
workspace/working/
workspace/for_paper/

workspace/input/**
!workspace/input/.gitkeep
!workspace/input/domains/.gitkeep

# Generated artifacts
workspace/archive/**/*.npz
workspace/archive/**/health_report.json
workspace/archive/**/*.{pth,pt,pkl,pickle,parquet,h5,hdf5,sqlite,sqlite3,db,zip}

# =========================
# SENSITIVE CONFIG
# =========================
config.yaml
.env
.env.local

# =========================
# DISTRIBUTABLES
# =========================
distributables/
shippables/

# =========================
# GENERATED OUTPUTS
# =========================
logs/
output/

# Ephemeral AlienCraft governance session dumps (belong under
# implementations/minecraft/AlienCraft/docs/working/architecture/)
/ANALYSIS_INDEX.md
/CODEBASE_GOVERNANCE_ANALYSIS.md
/CRITICAL_MISPLACEMENTS.md
/EXECUTIVE_SUMMARY.md
/LAYER_*_DEPENDENCY_ANALYSIS.md
/L2_L3_*_SESSION.md
/STEP_*_GOVERNANCE*.md
/analyze_dependencies.py
/analyze_responsibilities.py
/final_analysis.py

# =========================
# SUBMODULES / IMPLEMENTATIONS
# Let nested projects control themselves
# =========================

# DO NOT place Python/package ignores here
# DO NOT ignore implementations/**